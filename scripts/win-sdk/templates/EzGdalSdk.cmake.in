# EzGdalSdk CMake config (generated by scripts/win-sdk/generate-sdk.ps1)
# GDAL upstream version: @GdalUpstreamVersion@
# MaxRev runtime version: @MaxRevGdalVersion@
#
# 利用例 (verify/DummyPlugin/CMakeLists.txt 参照):
#   list(APPEND CMAKE_PREFIX_PATH "$ENV{EZGDAL_SDK_DIR}/cmake")
#   find_package(EzGdalSdk REQUIRED)
#   target_link_libraries(my_plugin PRIVATE EzGdalSdk::gdal)

if(NOT WIN32)
    message(FATAL_ERROR "EzGdalSdk は Windows 専用 (gdal.lib import library を提供)")
endif()

get_filename_component(_EzGdalSdk_root "${CMAKE_CURRENT_LIST_DIR}/.." ABSOLUTE)

# ezgdal が同梱する gdal.dll に対する import library。
# プラグインはこのターゲットにリンクし、ランタイムはホスト ezgdal プロセスに
# 既にロードされた gdal.dll が解決する。プラグイン側に gdal.dll を複製しない。
add_library(EzGdalSdk::gdal SHARED IMPORTED)
set_target_properties(EzGdalSdk::gdal PROPERTIES
    IMPORTED_IMPLIB               "${_EzGdalSdk_root}/lib/gdal.lib"
    INTERFACE_INCLUDE_DIRECTORIES "${_EzGdalSdk_root}/include/gdal"
)

set(EzGdalSdk_VERSION         "@GdalUpstreamVersion@")
set(EzGdalSdk_MAXREV_VERSION  "@MaxRevGdalVersion@")
set(EzGdalSdk_FOUND           TRUE)

unset(_EzGdalSdk_root)
